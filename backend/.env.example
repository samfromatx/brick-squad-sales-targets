# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Owner — Supabase user_id whose data the app reads/writes (no auth required from visitors)
OWNER_USER_ID=your-supabase-user-uuid

# Server
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,https://brick-squad-sales-targets.vercel.app
